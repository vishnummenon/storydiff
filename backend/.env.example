# Copy to .env — do not commit real credentials.

# SQLAlchemy / Alembic (psycopg v3 driver)
# Repo docker-compose maps Postgres to host port 5434 → use localhost:5434 when using Compose.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/storydiff

# AWS / SQS (ingestion events). For LocalStack: AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_ARTICLE_INGESTED_QUEUE_URL=
SQS_ARTICLE_ANALYZE_QUEUE_URL=
# Topic consensus refresh worker (``python -m storydiff.topic_refresh``)
SQS_TOPIC_REFRESH_QUEUE_URL=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Collection names (defaults match architecture/db_schema.md §5)
QDRANT_ARTICLE_EMBEDDINGS_COLLECTION=article_embeddings
QDRANT_TOPIC_EMBEDDINGS_COLLECTION=topic_embeddings

# Must match embedding model output dimension (384 for Ollama ``all-minilm`` or HF MiniLM)
EMBEDDING_VECTOR_SIZE=384

# COSINE | DOT | EUCLID — must match how vectors were produced
QDRANT_DISTANCE_METRIC=COSINE

# --- Article analysis worker (``python -m storydiff.analysis``) ---
# Requires Ollama (or OpenAI) for LLM; default embeddings use Ollama /api/embeddings (no PyTorch).
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.1:8b
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
EMBEDDING_BACKEND=ollama
# OLLAMA_EMBEDDING_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=all-minilm
# Optional: HF MiniLM via ``uv sync --extra embeddings-st`` and EMBEDDING_BACKEND=sentence_transformers
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
ANALYSIS_MAX_TEXT_CHARS=12000

# Topic assignment + refresh (Phase 3). See ``storydiff.analysis.settings`` for env names.
# TOPIC_CANDIDATE_TOP_N=20
# TOPIC_ASSIGN_THRESHOLD=0.45
# TOPIC_WEIGHT_VECTOR=0.35
# TOPIC_REFRESH_WINDOW_HOURS=720
# TOPIC_REFRESH_COOLDOWN_SECONDS=120
# TOPIC_REFRESH_MIN_EVIDENCE=1

# --- RSS feed fetcher (``python -m storydiff.rss``) ---
API_BASE_URL=http://127.0.0.1:8000
RSS_POLL_INTERVAL=900
RSS_FETCH_DELAY=2.0
RSS_FEEDS_CONFIG=
RSS_USER_AGENT=StoryDiff/0.1 (+https://github.com/storydiff)

# Netra observability (optional — enables LLM tracing, LangGraph spans, Qdrant/SQS/DB traces)
# NETRA_API_KEY=

# LangGraph Postgres checkpoint (same DB as DATABASE_URL by default; optional CHECKPOINT_DATABASE_URL)
LANGGRAPH_CHECKPOINT_ENABLED=true
# LANGGRAPH_CHECKPOINT_POOL_MAX=5
# CHECKPOINT_DATABASE_URL=
